# Database (PostgreSQL)
# Local with Docker: use the URL below (matches docker-compose.yml).
# Otherwise point to your own Postgres host.
DATABASE_URL="postgresql://susu:susu_local@localhost:5433/susu_system?schema=public"

# Auth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Redis – optional for local dev (docker-compose runs Redis on localhost:6379).
# For Upstash in production: https://upstash.com
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-token"

# Optional: session timeout in minutes (default 30)
SESSION_TIMEOUT_MINUTES=30

# SMS (Arkesel) – optional; if set, SMS is sent for key notifications
# ARKESEL_API_KEY=your-api-key
# ARKESEL_SENDER_ID=YourSenderID
